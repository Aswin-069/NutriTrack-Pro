# NutriTrack Pro Backend Environment Variables
# Set these in your hosting provider (Render, Railway, Fly.io, Heroku)

# Server Port (automatically assigned by Render/Railway)
PORT=5000

# Environment mode ('production' or 'development')
NODE_ENV=production

# PostgreSQL Database Connection String (Render Postgres, Supabase, Neon, Railway Postgres)
# Must include sslmode=require for production cloud databases
DATABASE_URL="postgresql://username:password@ep-host.region.aws.neon.tech/nutritrack_db?sslmode=require"

# Secure random JWT secret key (Generate via `openssl rand -hex 32`)
JWT_SECRET="supersecretjwtkey123_production_change_me"

# Frontend URL (your Netlify production deployment URL)
# Example: https://nutritrack-pro.netlify.app
FRONTEND_URL=https://your-netlify-app-name.netlify.app

# USDA Food Data Central API Key (Free from https://fdc.nal.usda.gov/api-key-signup.html)
FDC_API_KEY=KOzwvgfXWvhVqdlzJdx9ukAxdNJJVEdjTpapfpMe

# Gmail SMTP Email Delivery Credentials (for OTP password resets)
SMTP_EMAIL=aswinacharya2006@gmail.com
SMTP_APP_PASSWORD=tpgc lcsl jueh twyb
