# NutriTrack Pro Frontend Environment Variables
# For Netlify deployment, add this variable in Netlify Site Settings > Environment Variables

# Set this to your live production backend URL (e.g. Render, Railway, Fly.io, or Heroku)
# Do NOT include a trailing slash
# Example: VITE_API_URL=https://nutritrack-pro-backend.onrender.com
VITE_API_URL=
